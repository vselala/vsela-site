 <description>&lt;div class=&quot;field field-name-field-image field-type-image field-label-hidden&quot;&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;a href=&quot;/%D1%81%D1%82%D0%B8%D1%85/%D0%BF%D0%BE%D0%B7%D0%B4%D1%80%D0%B0%D0%B2%D0%BB%D0%B5%D0%BD%D0%B8%D0%B5-%D0%B2-%D0%B4%D0%B5%D0%BD%D1%8C-%D1%80%D0%BE%D1%81%D1%81%D0%B8%D0%B8-%D1%81%D1%82%D0%B8%D1%85%D0%B8-12-%D0%B8%D1%8E%D0%BD%D1%8F&quot;&gt;&lt;img src=&quot;http://vse.la/images/styles/thumb180/public/stihi_images/723561842.jpg&quot; width=&quot;180&quot; height=&quot;120&quot; alt=&quot;&quot; /&gt;&lt;/a&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;field field-name-body field-type-text-with-summary field-label-hidden&quot;&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;p&gt; &lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#0000CD&quot;&gt;&lt;span style=&quot;font-size:18px&quot;&gt;&lt;em&gt;&lt;strong&gt;Поздравление в день России, стихи 12 июня&lt;/strong&gt;&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#0000CD&quot;&gt;&lt;span style=&quot;font-size:18px&quot;&gt;&lt;em&gt;&lt;strong&gt;Я так хочу, чтоб в день России люди -&lt;/strong&gt;&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#0000CD&quot;&gt;&lt;span style=&quot;font-size:18px&quot;&gt;&lt;em&gt;&lt;strong&gt;Перехотели меж собою воевать!&lt;/strong&gt;&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#0000CD&quot;&gt;&lt;span style=&quot;font-size:18px&quot;&gt;&lt;em&gt;&lt;strong&gt;И не решали кто преступники - кто судьи! -&lt;/strong&gt;&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#0000CD&quot;&gt;&lt;span style=&quot;font-size:18px&quot;&gt;&lt;em&gt;&lt;strong&gt;Скорей друг друга захотели бы обнять!&lt;/strong&gt;&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;field field-name-field-tematika field-type-taxonomy-term-reference field-label-inline clearfix&quot;&gt;&lt;div class=&quot;field-label&quot;&gt;Тематика:&amp;nbsp;&lt;/div&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;a href=&quot;/tematika/prazdniki&quot;&gt;Праздники&lt;/a&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</description>
