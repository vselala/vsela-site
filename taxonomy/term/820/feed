<item>
 <title>Багряных красок небосвод</title>
 <link>https://vse.la/stih/bagryanyh-krasok-nebosvod</link>
 <description>&lt;div class=&quot;field field-name-body field-type-text-with-summary field-label-hidden&quot;&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Уютный дом, тепло ласкает,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Томленье духа, бездна сна,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Покой волнами обнимает,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Витая, музыка слышна.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Светло. И тают тени бликов,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Чаруя, льётся нежный звук,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;И в колыбели сладкой тихо&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Плывёшь в забвенья томный круг.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;И стрелки замедляют время,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Сидишь, приблизившись к огню,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Виденьем стелется поэма —&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Под сердцем бережно храню.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Сгорают горечь и прохлада,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Из лампы льётся мягкий свет,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Коснувшись тайны тихим  взглядом,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Украсив отраженьем плед.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Сидишь, качаясь в чувствах давних,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;А за окном луна плывёт,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;В осенней полночи туманной&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Багряных красок небосвод.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Коснётся луч, блеснёт, мерцая,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Виденьем ярким озарит,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Приблизив грёзы, замираю,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;А кровь желанием бурлит.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Сжимаю руки и коленки,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Исчезну в пламени огня,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Златым лучом взлетев по стенке,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#8B4513&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Любви мелодией маня...17.09.14&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;
&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;field field-name-field-tematika field-type-taxonomy-term-reference field-label-inline clearfix&quot;&gt;&lt;div class=&quot;field-label&quot;&gt;Тематика:&amp;nbsp;&lt;/div&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;a href=&quot;/tematika/lirika&quot;&gt;Лирика&lt;/a&gt;&lt;/div&gt;&lt;div class=&quot;field-item odd&quot;&gt;&lt;a href=&quot;/tematika/romanticheskie&quot;&gt;Романтические&lt;/a&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</description>
