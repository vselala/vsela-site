<item>
 <title>Осенняя магия.</title>
 <link>https://vse.la/%D1%81%D1%82%D0%B8%D1%85/%D0%BE%D1%81%D0%B5%D0%BD%D0%BD%D1%8F%D1%8F-%D0%BC%D0%B0%D0%B3%D0%B8%D1%8F</link>
 <description>&lt;div class=&quot;field field-name-field-image field-type-image field-label-hidden&quot;&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;a href=&quot;/%D1%81%D1%82%D0%B8%D1%85/%D0%BE%D1%81%D0%B5%D0%BD%D0%BD%D1%8F%D1%8F-%D0%BC%D0%B0%D0%B3%D0%B8%D1%8F&quot;&gt;&lt;img src=&quot;https://vse.la/images/styles/thumb180/public/stihi_images/111.gif?itok=EMv0XTm5&quot; width=&quot;103&quot; height=&quot;140&quot; alt=&quot;&quot; /&gt;&lt;/a&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;field field-name-body field-type-text-with-summary field-label-hidden&quot;&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Ты не внял бы меня, другую,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Не пришёл бы, не пожалел,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Я сегодня с тобой танцую,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Вечер осени душу согрел.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;И волнует хрусталь бокалов,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Серебрится капелью звон,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Дрожи в чувствах мне мало, мало..&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Так желанен глубинный стон.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Годы, реки, туман и пекло,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Боль пронзительно велика,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;И не высказать словом бегло,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;То, что в сердце кольнёт слегка.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Ты не стал бы ласкать и нежить,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Не вошёл бы в закрытый дом,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Я звала томных красок нежность,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Рисовала вуаль зонтом.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;И пульсирует в жилах пламя,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Обжигая святой волной,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Словно  ангел коснулся в храме,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Засиял золотой луной.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Расширяются неба грани,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;И закат янтарём горит,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Окрыляя  любви желанье,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Попадая со мною в ритм.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Вожделеньем томима и страстью,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Ночь пленительно хороша,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;И осенняя магия власти,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;Учащённо заставит дышать.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#800000&quot;&gt;&lt;span style=&quot;font-size:24px&quot;&gt;&lt;em&gt;09.09.14&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;field field-name-field-tematika field-type-taxonomy-term-reference field-label-inline clearfix&quot;&gt;&lt;div class=&quot;field-label&quot;&gt;Тематика:&amp;nbsp;&lt;/div&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;a href=&quot;/tematika/muzhchine&quot;&gt;Мужчине&lt;/a&gt;&lt;/div&gt;&lt;div class=&quot;field-item odd&quot;&gt;&lt;a href=&quot;/tematika/priznaniya-v-lyubvi&quot;&gt;Признания в любви&lt;/a&gt;&lt;/div&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;a href=&quot;/tematika/romanticheskie&quot;&gt;Романтические&lt;/a&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</description>
