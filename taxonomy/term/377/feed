<item>
 <title>Дух глубин</title>
 <link>https://vse.la/%D1%81%D1%82%D0%B8%D1%85/%D0%B4%D1%83%D1%85-%D0%B3%D0%BB%D1%83%D0%B1%D0%B8%D0%BD</link>
 <description>&lt;div class=&quot;field field-name-field-image field-type-image field-label-hidden&quot;&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;a href=&quot;/%D1%81%D1%82%D0%B8%D1%85/%D0%B4%D1%83%D1%85-%D0%B3%D0%BB%D1%83%D0%B1%D0%B8%D0%BD&quot;&gt;&lt;img src=&quot;https://vse.la/images/styles/thumb180/public/stihi_images/1349191547_grust_010.jpg&quot; width=&quot;180&quot; height=&quot;102&quot; alt=&quot;&quot; /&gt;&lt;/a&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;field field-name-body field-type-text-with-summary field-label-hidden&quot;&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Ты, пройдя огонь и волчьи стаи,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Сохранила сердце молодым,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Так зачем сейчас слезу пускаешь,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Не отчаивайся, не грусти.&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Где-то есть твоей мечты стихия,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;И проснёшься павой средь вершин,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Не грусти, что всё в огне сгорело,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Главное, остался – дух глубин.&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Пусть линяет старенькое платье,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Ты везде прекрасна, хороша,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Ведь божественно твоё объятье,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Изнутри цветёт, растёт душа.&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Взор простой доверчивый, лучистый,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;И любви объятья, но для тех,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Кто приятен добротой и чистый,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;И живёт по совести для всех.&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Разбегусь, взлечу с обрыва в небо,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Там, где море с чайками шумит,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Поплыву, мне страх уже неведом,&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;em&gt;&lt;span style=&quot;font-size:28px&quot;&gt;Пусть гроза и гром сильней гремит.&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;em&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;14.07.14&lt;/span&gt;&lt;/em&gt;&lt;/p&gt;
