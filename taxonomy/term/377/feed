<item>
 <title>Угадай мой цветик-цвет??</title>
 <link>https://vse.la/%D1%81%D1%82%D0%B8%D1%85/%D1%83%D0%B3%D0%B0%D0%B4%D0%B0%D0%B9-%D0%BC%D0%BE%D0%B9-%D1%86%D0%B2%D0%B5%D1%82%D0%B8%D0%BA-%D1%86%D0%B2%D0%B5%D1%82</link>
 <description>&lt;div class=&quot;field field-name-field-image field-type-image field-label-hidden&quot;&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;a href=&quot;/%D1%81%D1%82%D0%B8%D1%85/%D1%83%D0%B3%D0%B0%D0%B4%D0%B0%D0%B9-%D0%BC%D0%BE%D0%B9-%D1%86%D0%B2%D0%B5%D1%82%D0%B8%D0%BA-%D1%86%D0%B2%D0%B5%D1%82&quot;&gt;&lt;img src=&quot;https://vse.la/images/styles/thumb180/public/stihi_images/a32a71f903f5t.jpg&quot; width=&quot;180&quot; height=&quot;120&quot; alt=&quot;&quot; /&gt;&lt;/a&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;field field-name-body field-type-text-with-summary field-label-hidden&quot;&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;span style=&quot;font-size:36px&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif&quot;&gt;&lt;em&gt;Я подарю тебе полянку,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;span style=&quot;font-size:36px&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif&quot;&gt;&lt;em&gt;Там разные растут цветы,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;span style=&quot;font-size:36px&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif&quot;&gt;&lt;em&gt;Меня едва найдешь в толпе ты,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;span style=&quot;font-size:36px&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif&quot;&gt;&lt;em&gt;Невзрачный вид, внутри костры.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;span style=&quot;font-size:36px&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif&quot;&gt;&lt;em&gt;Не рассмотреть среди красоток,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;span style=&quot;font-size:36px&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif&quot;&gt;&lt;em&gt;Не услыхать мой тихий звон,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;span style=&quot;font-size:36px&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif&quot;&gt;&lt;em&gt;И нрав несмел, обидчив, кроток,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;span style=&quot;font-size:36px&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif&quot;&gt;&lt;em&gt;Меня узнает Орион.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;span style=&quot;font-size:36px&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif&quot;&gt;&lt;em&gt;Как ёмко мира наслажденье,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;span style=&quot;font-size:36px&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif&quot;&gt;&lt;em&gt;И музыкой звучит весь мир,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;span style=&quot;font-size:36px&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif&quot;&gt;&lt;em&gt;Достаточно одно мгновенье,&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt;&lt;span style=&quot;color:#0000FF&quot;&gt;&lt;span style=&quot;font-size:36px&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif&quot;&gt;&lt;em&gt;Чтобы затих земли эфир.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p class=&quot;rtecenter&quot;&gt; &lt;/p&gt;

