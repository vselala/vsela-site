 <title>Твоя девочка</title>
 <link>https://vse.la/%D1%81%D1%82%D0%B8%D1%85/%D1%82%D0%B2%D0%BE%D1%8F-%D0%B4%D0%B5%D0%B2%D0%BE%D1%87%D0%BA%D0%B0</link>
 <description>&lt;div class=&quot;field field-name-field-image field-type-image field-label-hidden&quot;&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;a href=&quot;/%D1%81%D1%82%D0%B8%D1%85/%D1%82%D0%B2%D0%BE%D1%8F-%D0%B4%D0%B5%D0%B2%D0%BE%D1%87%D0%BA%D0%B0&quot;&gt;&lt;img src=&quot;https://vse.la/images/styles/thumb180/public/stihi_images/95_nedel_obnimaet_ee.jpg&quot; width=&quot;180&quot; height=&quot;114&quot; alt=&quot;&quot; /&gt;&lt;/a&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;field field-name-body field-type-text-with-summary field-label-hidden&quot;&gt;&lt;div class=&quot;field-items&quot;&gt;&lt;div class=&quot;field-item even&quot;&gt;&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Я была твоей девочкой,&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Твоей самой желанной,&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Интриганкой и стервочкой,&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Сумасшедшей и странной,&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Самой непредсказуемой,&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Оттого интересной…&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Это было безумием –  &lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Мы признаемся честно.&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Посвятить тебе жизнь&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;И идти за тобой –&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Лишь бы вместе, всегда,&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;По дороге любой!&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Ты не смог оценить,&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Я так долго ждала…&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Я была твоей девочкой,&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;color:#4B0082&quot;&gt;&lt;strong&gt;&lt;em&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Бескорыстной, была…&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
